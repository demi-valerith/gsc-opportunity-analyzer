{
  "name": "@demi-valerith/gsc-opportunity-analyzer",
  "version": "1.0.0",
  "description": "Find striking-distance queries, CTR gaps, rising demand, decay, and page opportunities in Google Search Console CSV exports.",
  "type": "module",
  "main": "./src/index.mjs",
  "types": "./src/index.d.ts",
  "bin": {
    "gsc-opportunity": "./bin/gsc-opportunity.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs",
      "default": "./src/index.mjs"
    }
  },
  "files": [
    "action.yml",
    "action/index.mjs",
    "bin/gsc-opportunity.mjs",
    "src/csv.mjs",
    "src/engine.mjs",
    "src/format.mjs",
    "src/index.d.ts",
    "src/index.mjs",
    "LICENSE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "check": "node --check src/csv.mjs && node --check src/engine.mjs && node --check src/format.mjs && node --check src/index.mjs && node --check bin/gsc-opportunity.mjs && node --check action/index.mjs",
    "test": "node --test"
  },
  "keywords": [
    "google-search-console",
    "gsc",
    "seo",
    "github-action",
    "csv"
  ],
  "author": "Demi Valerith",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/demi-valerith/gsc-opportunity-analyzer.git"
  },
  "homepage": "https://seoreportkit.com/tools/gsc-opportunity-analysis/",
  "bugs": {
    "url": "https://github.com/demi-valerith/gsc-opportunity-analyzer/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
